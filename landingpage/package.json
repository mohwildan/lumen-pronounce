{
  "name": "nextjs-ts-tailwind-starter",
  "version": "0.0.1",
  "description": "A Next.js starter template with TypeScript and Tailwind CSS",
  "author": "Ali Piry",
  "license": "MIT",
  "keywords": [
    "nextjs",
    "typescript",
    "tailwindcss",
    "starter"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/alipiry/nextjs-ts-tailwind-starter.git"
  },
  "bugs": {
    "url": "https://github.com/alipiry/nextjs-ts-tailwind-starter/issues"
  },
  "homepage": "https://github.com/alipiry/nextjs-ts-tailwind-starter#readme",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:strict": "eslint --max-warnings=0 src",
    "format": "prettier -w .",
    "format:check": "prettier -c .",
    "typecheck": "tsc --noEmit --incremental false",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.25.0",
  "dependencies": {
    "@supabase/supabase-js": "^2.105.4",
    "@tailwindcss/postcss": "^4.1.18",
    "framer-motion": "^12.23.26",
    "next": "^16.0.10",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "sharp": "^0.34.5",
    "stripe": "^22.1.1"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^25.0.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "clsx": "^2.1.1",
    "eslint": "^9.39.2",
    "eslint-config-next": "^16.0.10",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "postcss": "^8.5.6",
    "prettier": "^3.7.4",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3"
  }
}
